# Pprof Proxy - routes pprof requests to node CL/EL pprof endpoints
# Access pattern:
#   /pprof/cl/<node-name>/... -> http://<node-private-ip>:6060/...
#   /pprof/el/<node-name>/... -> http://<node-private-ip>:6161/...
#
# Uses per-node static location blocks (not regex + dynamic upstream)
# because nginx bypasses upstream lookup when proxy_pass contains a
# variable, causing DNS resolution failures and 502 errors.

%{~ for i, n in nodes }
upstream ${n.name}_cl_pprof {
    server ${n.private_ip}:6060;
}
upstream ${n.name}_el_pprof {
    server ${n.private_ip}:6161;
}
%{~ endfor }

server {
    listen 6060;
    server_name localhost;

%{~ for i, n in nodes }
    # ${n.name} CL pprof (port 6060)
    location /pprof/cl/${n.name}/ {
        proxy_pass http://${n.name}_cl_pprof/;
        proxy_http_version 1.1;
        # CPU profiling blocks for ?seconds=N (default 30s).
        # 600s allows profiles up to 10 minutes.
        proxy_read_timeout 600s;
        proxy_connect_timeout 10s;
    }

    # ${n.name} EL pprof (port 6161)
    location /pprof/el/${n.name}/ {
        proxy_pass http://${n.name}_el_pprof/;
        proxy_http_version 1.1;
        proxy_read_timeout 600s;
        proxy_connect_timeout 10s;
    }
%{~ endfor }

    # Health check endpoint
    location /health {
        return 200 'OK';
        add_header Content-Type text/plain;
    }

    # List available nodes
    location /nodes {
        default_type application/json;
        return 200 '{"nodes": [%{~ for i, n in nodes }${i > 0 ? "," : ""}"${n.name}"%{~ endfor }]}';
    }
}
