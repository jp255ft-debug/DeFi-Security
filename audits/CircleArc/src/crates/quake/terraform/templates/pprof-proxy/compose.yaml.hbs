name: pprof-proxy

services:
  # Routes pprof requests to nodes by name and layer
  # Example: GET http://localhost:6060/pprof/cl/node0/debug/pprof/heap -> http://<node0-private-ip>:6060/debug/pprof/heap
  # Example: GET http://localhost:6060/pprof/el/node0/debug/pprof/heap -> http://<node0-private-ip>:6161/debug/pprof/heap
  pprof-proxy:
    image: nginx
    container_name: pprof-proxy
    volumes:
      - ./pprof-proxy.conf:/etc/nginx/conf.d/default.conf:ro
    ports:
      - "6060:6060"
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: 128M
