global:
  scrape_interval: 10s
  evaluation_interval: 30s

scrape_configs:
  - job_name: 'cc_node_exporter'
    static_configs:
      - targets: ['node-exporter:9100']
        labels:
          instance: 'cc'
%{~ for i, n in nodes }
  - job_name: '${n.name}_cl'
    metrics_path: "/metrics"
    static_configs:
      - targets: ['${n.private_ip}:29000']
        labels:
          client_name: "malachite"
  - job_name: '${n.name}_el'
    static_configs:
      - targets: ['${n.private_ip}:9001']
        labels:
          client_name: "reth"
%{~ endfor }
