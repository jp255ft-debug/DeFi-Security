# =============================================================================
# .gitignore — DeFi Security Workspace
# Protege credenciais, chaves, findings confidenciais e artefatos de build
# =============================================================================

# ── Credenciais e Configuração Sensível ──────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
keystore.*
secrets.*
credentials.*
config.local.*
*.secret

# ── Chaves Privadas e Wallets ────────────────────────────────────────────────
**/keystore/
**/wallet/
**/accounts/
**/private/
mnemonic*
private*
wallet*.json
**/hardhat/accounts.json

# ── AUDITS — Repositório Privado (Confidencial) ─────────────────────────────
# Toda a pasta audits/ é mantida em repositório privado separado.
# NADA de auditoria deve vazar para o público.
audits/

# ── Dependências e Artefatos de Build ────────────────────────────────────────
node_modules/
**/node_modules/
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.cache/
artifacts/
cache/
typechain-types/
**/artifacts/
**/cache/
**/typechain-types/
lib/
**/lib/
**/src/lib/
**/poc/lib/
**/latam_contracts/lib/

# ── Ambientes Virtuais Python ────────────────────────────────────────────────
venv/
.venv/
env/
virtualenv/
*.egg

# ── IDE e Editor ─────────────────────────────────────────────────────────────
.vscode/
**/.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Resultados de Ferramentas ────────────────────────────────────────────────
**/slither_results.json
**/aderyn_results.json
**/mythril_results.json

# ── Logs e Outputs ───────────────────────────────────────────────────────────
*.log
logs/
**/logs/
output/
**/output/
*.out
*.txt
!requirements*.txt
!RELATORIO_*.md
!CASE_STUDY_*.md
!README*.md

# ── Docker ───────────────────────────────────────────────────────────────────
docker-compose.override.yml
*.dockercontext

# ── Hardhat / Foundry ────────────────────────────────────────────────────────
broadcast/
**/broadcast/
**/out/
**/out/*.sol/
**/out/*.yul/
**/out/*.vy/

# ── H2V-Trust — Não pertence ao DeFi Security ────────────────────────────────
alembic.ini
docker-compose*.yml
render.yaml
Makefile
.env.production
backend/
frontend/
iot/
monitoring/
nginx/
contracts/
tests/

