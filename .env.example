# =============================================================================
# DePIN Security Workspace — Environment Variables
# =============================================================================
# Copie este arquivo para .env e preencha com suas credenciais.
# ATENCAO: NUNCA commite o .env real (ja esta no .gitignore).

# --- Ethereum/Web3 ---
# Chave privada Ethereum (0x... formato)
# Usada para assinar dados (ECDSA) e autenticar na Streamr
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# --- Streamr Network ---
# Stream ID criado no Streamr Hub (https://streamr.network/hub)
# 1. Conecte sua MetaMask (mesma carteira da PRIVATE_KEY)
# 2. Clique em "Create Stream"
# 3. Nome: DIMO-Secure-Telemetry
# 4. Cole o Stream ID gerado (ex: 0x123.../DIMO-Secure-Telemetry)
STREAMR_STREAM_ID=0xseu_stream_id_aqui

# --- DIMO Network (apenas para modo producao) ---
# Credenciais do seu veiculo cadastrado na rede DIMO
DIMO_CLIENT_ID=seu_dimo_client_id
DIMO_DOMAIN=seu_dimo_domain
VEHICLE_TOKEN_ID=0
